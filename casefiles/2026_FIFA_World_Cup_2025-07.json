wikieditor"], "is_revert": true, "reverted_editor": "1995hoo"}, {"revid": 1300806384, "parentid": 1300800780, "user": "1995hoo", "timestamp": "2025-07-16T14:06:33Z", "size": 160603, "sha1": "030b1306284fc4c44196ce4ddd2d0354348e8f3b", "comment": "Undid revision [[Special:Diff/1300800780|1300800780]] by [[Special:Contributions/Assadzadeh|Assadzadeh]] ([[User talk:Assadzadeh|talk]])\u2014I completely disagree with that because it introduces another inconsistency. If you're going to insist on \"what FIFA says,\" then you're going to reopen the whole argument about the people who demand that the sport itself be called \"football\" instead of \"soccer.\" FIFA's use of the hyphen is simply due to their own use of a particular English variant.", "tags": ["mw-undo", "wikieditor"], "is_revert": true, "reverted_editor": "Assadzadeh"}, {"revid": 1301063583, "parentid": 1300806384, "user": "Reschultzed", "timestamp": "2025-07-17T22:20:40Z", "size": 160552, "sha1": "c93a2d8c9d2488fb7c5d04a08577cc519a2738c8", "comment": "", "tags": ["wikieditor"], "is_revert": false, "reverted_editor": null}, {"revid": 1301072019, "parentid": 1301063583, "user": "Icevol26", "timestamp": "2025-07-17T23:22:32Z", "size": 160549, "sha1": "c2e321f62d208d95a845af8cf7a6fa448c6fbcc7", "comment": "/* United States immigration enforcement */There to it", "tags": ["mobile edit", "mobile web edit"], "is_revert": false, "reverted_editor": null}, {"revid": 1301419626, "parentid": 1301072019, "user": "Bostart", "timestamp": "2025-07-19T18:51:51Z", "size": 160561, "sha1": "50fbab6a8435342db6939945c4e2b198e64614ff", "comment": "", "tags": ["mobile edit", "mobile app edit", "ios app edit", "mw-reverted", "app-section-source"], "is_revert": false, "reverted_editor": null}, {"revid": 1301444117, "parentid": 1301419626, "user": "JalenBarks", "timestamp": "2025-07-19T22:05:29Z", "size": 160549, "sha1": "c2e321f62d208d95a845af8cf7a6fa448c6fbcc7", "comment": "Reverted 1 edit by [[Special:Contributions/Bostart|Bostart]] (